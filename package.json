{
  "name": "@hipstacowboys/design-system",
  "version": "1.3.0",
  "description": "Vue + SCSS design system built from Figma design system file",
  "main": "index.js",
  "module": "index.js",
  "type": "module",
  "files": [
    "components",
    "tokens",
    "index.js",
    "README.md",
    "COMPONENTS.md",
    "CHANGELOG.md",
    "docs"
  ],
  "exports": {
    ".": "./index.js",
    "./tokens/*": "./tokens/*",
    "./components/*": "./components/*"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "release:patch": "node scripts/release.js patch && git push --follow-tags",
    "release:minor": "node scripts/release.js minor && git push --follow-tags",
    "release:major": "node scripts/release.js major && git push --follow-tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hipstacowboys/design-system.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "design-system",
    "components",
    "scss",
    "figma"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Hipstacowboys/design-system/issues"
  },
  "homepage": "https://github.com/Hipstacowboys/design-system#readme",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "sass-embedded": "^1.83.0",
    "vite": "^6.0.0",
    "vue": "^3.5.13"
  },
  "dependencies": {
    "@phosphor-icons/vue": "^2.2.1"
  }
}
